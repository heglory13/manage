generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum TransactionType {
  STOCK_IN
  STOCK_OUT
}

enum StocktakingStatus {
  CHECKING // Đang kiểm kê
  PENDING // Chờ duyệt
  APPROVED // Đã duyệt
  REJECTED // Từ chối
}

enum PreliminaryCheckStatus {
  PENDING // Chờ kiểm tra chi tiết
  COMPLETED // Đã kiểm tra chi tiết
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String // bcrypt hashed
  name         String
  role         Role     @default(STAFF)
  refreshToken String? // hashed refresh token
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions       InventoryTransaction[]
  stocktakingRecords StocktakingRecord[]
  preliminaryChecks  PreliminaryCheck[]
  savedFilters       SavedFilter[]

  @@map("users")
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  code     String    @unique // Mã viết hoa không dấu (DONGHO, DIENTHOAI, ...)
  products Product[]

  @@map("categories")
}

model Product {
  id             String   @id @default(uuid())
  name           String
  sku            String   @unique
  price          Decimal  @db.Decimal(15, 2)
  categoryId     String
  stock          Int      @default(0) // Tồn kho hiện tại
  minThreshold   Int      @default(0) // Ngưỡng tồn kho tối thiểu
  maxThreshold   Int      @default(0) // Ngưỡng tồn kho tối đa
  isDiscontinued Boolean  @default(false) // Ngừng kinh doanh
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category           Category               @relation(fields: [categoryId], references: [id])
  transactions       InventoryTransaction[]
  warehousePositions WarehousePosition[]
  stocktakingItems   StocktakingItem[]

  @@map("products")
}

model InventoryTransaction {
  id                  String          @id @default(uuid())
  productId           String
  type                TransactionType
  quantity            Int
  userId              String
  skuComboId          String?
  productConditionId  String?
  storageZoneId       String?
  actualStockDate     DateTime? // Thời gian nhập kho thực tế
  warehousePositionId String? // Vị trí kho cụ thể
  preliminaryCheckId  String? // Liên kết phiếu kiểm sơ bộ
  notes               String?
  createdAt           DateTime        @default(now())

  product           Product            @relation(fields: [productId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  skuCombo          SkuCombo?          @relation(fields: [skuComboId], references: [id])
  productCondition  ProductCondition?  @relation(fields: [productConditionId], references: [id])
  storageZone       StorageZone?       @relation(fields: [storageZoneId], references: [id])
  warehousePosition WarehousePosition? @relation(fields: [warehousePositionId], references: [id])
  preliminaryCheck  PreliminaryCheck?  @relation(fields: [preliminaryCheckId], references: [id])

  @@index([productId, createdAt])
  @@index([type, createdAt])
  @@map("inventory_transactions")
}

model WarehouseLayout {
  id           String   @id @default(uuid())
  name         String
  rows         Int // Số hàng trong grid
  columns      Int // Số cột trong grid
  layoutMode   String   @default("GRID") // GRID | FREE
  canvasWidth  Int      @default(1200)
  canvasHeight Int      @default(700)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  positions WarehousePosition[]

  @@map("warehouse_layouts")
}

model WarehousePosition {
  id           String  @id @default(uuid())
  layoutId     String
  row          Int
  column       Int
  x            Int     @default(0)
  y            Int     @default(0)
  width        Int     @default(100)
  height       Int     @default(80)
  label        String? // Nhãn vị trí (A1, B2, ...)
  productId    String?
  isActive     Boolean @default(true) // Ô hoạt động hay ô trống
  maxCapacity  Int? // Sức chứa tối đa (null = không giới hạn)
  currentStock Int     @default(0) // Tồn kho hiện tại tại vị trí

  layout                WarehouseLayout        @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  product               Product?               @relation(fields: [productId], references: [id])
  inventoryTransactions InventoryTransaction[]

  @@unique([layoutId, label])
  @@map("warehouse_positions")
}

model WarehouseConfig {
  id          String @id @default(uuid())
  maxCapacity Int // Sức chứa tối đa

  @@map("warehouse_config")
}

model StocktakingRecord {
  id          String            @id @default(uuid())
  status      StocktakingStatus @default(PENDING)
  createdBy   String
  cutoffTime  DateTime          @default(now()) // Thời gian cut-off
  submittedAt DateTime? // Thời gian submit
  mode        String            @default("full") // 'full' | 'selected'
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  creator       User                       @relation(fields: [createdBy], references: [id])
  items         StocktakingItem[]
  statusHistory StocktakingStatusHistory[]

  @@map("stocktaking_records")
}

model StocktakingItem {
  id                String  @id @default(uuid())
  recordId          String
  productId         String
  systemQuantity    Int // Số lượng trên hệ thống
  actualQuantity    Int // Số lượng thực tế
  discrepancy       Int // = actualQuantity - systemQuantity
  evidenceUrl       String? // URL ảnh/file minh chứng
  discrepancyReason String? // Nguyên nhân chênh lệch

  record  StocktakingRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  product Product           @relation(fields: [productId], references: [id])

  @@map("stocktaking_items")
}

model StocktakingStatusHistory {
  id        String            @id @default(uuid())
  recordId  String
  status    StocktakingStatus
  changedBy String?
  changedAt DateTime          @default(now())
  note      String?

  record StocktakingRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@map("stocktaking_status_history")
}

model WarehouseType {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  preliminaryChecks PreliminaryCheck[]

  @@map("warehouse_types")
}

model PreliminaryCheck {
  id               String                 @id @default(uuid())
  classificationId String
  quantity         Int
  warehouseTypeId  String?
  imageUrl         String?
  note             String?
  status           PreliminaryCheckStatus @default(PENDING)
  createdBy        String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  classification        Classification         @relation(fields: [classificationId], references: [id])
  warehouseType         WarehouseType?         @relation(fields: [warehouseTypeId], references: [id])
  creator               User                   @relation(fields: [createdBy], references: [id])
  inventoryTransactions InventoryTransaction[]

  @@map("preliminary_checks")
}

// === Thuộc tính sản phẩm ===

model Classification {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  skuCombos         SkuCombo[]
  preliminaryChecks PreliminaryCheck[]

  @@map("classifications")
}

model Color {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  skuCombos SkuCombo[]

  @@map("colors")
}

model Size {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  skuCombos SkuCombo[]

  @@map("sizes")
}

model Material {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  skuCombos SkuCombo[]

  @@map("materials")
}

// === SKU tổng hợp ===

model SkuCombo {
  id               String   @id @default(uuid())
  classificationId String
  colorId          String
  sizeId           String
  materialId       String
  compositeSku     String   @unique
  createdAt        DateTime @default(now())

  classification        Classification         @relation(fields: [classificationId], references: [id])
  color                 Color                  @relation(fields: [colorId], references: [id])
  size                  Size                   @relation(fields: [sizeId], references: [id])
  material              Material               @relation(fields: [materialId], references: [id])
  inventoryTransactions InventoryTransaction[]

  @@unique([classificationId, colorId, sizeId, materialId])
  @@map("sku_combos")
}

// === Tình trạng hàng hoá ===

model ProductCondition {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  inventoryTransactions InventoryTransaction[]

  @@map("product_conditions")
}

// === Khu vực hàng hoá ===

model StorageZone {
  id           String   @id @default(uuid())
  name         String   @unique
  maxCapacity  Int
  currentStock Int      @default(0)
  createdAt    DateTime @default(now())

  inventoryTransactions InventoryTransaction[]

  @@map("storage_zones")
}

// === Bộ lọc đã lưu ===

model SavedFilter {
  id        String   @id @default(uuid())
  userId    String
  pageKey   String
  name      String
  filters   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, pageKey])
  @@map("saved_filters")
}

// === Nhật ký hoạt động ===

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  action    String
  tableName String
  recordId  String
  oldData   Json?
  newData   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tableName])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}
